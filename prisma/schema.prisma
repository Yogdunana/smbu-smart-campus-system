generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  studentId     String    @unique
  name          String
  passwordHash  String
  email         String?   @unique
  phone         String?
  wechat        String?
  github        String?
  weibo         String?
  role          Role      @default(STUDENT)
  locale        String    @default("zh")
  gender        String?
  ethnicity     String?
  idCardNumber  String?
  photoUrl      String?
  grade         String?
  department    String?
  major         String?
  className     String?
  volunteerNumber String? @unique
  profileStatus ProfileStatus @default(DRAFT)
  profileReviewNote String?
  plans         Plan[]
  personalTasks PersonalTask[]
  awards        Award[]
  skillTags     UserSkillTag[]
  volunteerRecords VolunteerRecord[]
  taskAssignees TaskAssignee[]
  organizationLeaders OrganizationLeader[]
  auditLogs     AuditLog[]
  createdTasks  OrganizationTask[] @relation("TaskCreator")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([studentId])
  @@index([role])
  @@index([volunteerNumber])
}

model Plan {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  status      PlanStatus @default(PENDING)
  startTime   DateTime
  endTime     DateTime
  location    String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([userId])
  @@index([status])
  @@index([startTime])
}

model PersonalTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  source      TaskSource @default(MANUAL)
  sourceRef   String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([userId])
  @@index([status])
}

model Organization {
  id            String         @id @default(cuid())
  fullName      String
  shortName     String
  logoUrl       String?
  description   String?
  nature        OrganizationNature @default(STUDENT_ORG)
  status        OrgStatus      @default(ACTIVE)
  teacherAdvisor String?
  contactInfo   String?
  leaders       OrganizationLeader[]
  departments   Department[]
  tasks         OrganizationTask[]
  auditLogs     AuditLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@index([status])
}

model OrganizationLeader {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("负责人")
  createdAt      DateTime     @default(now())
  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Department {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          OrganizationTask[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@index([organizationId])
}

model OrganizationTask {
  id              String           @id @default(cuid())
  title           String
  description     String?
  type            TaskType         @default(SINGLE_DEPT)
  status          OrgTaskStatus    @default(PENDING_VIEW)
  priority        Priority         @default(MEDIUM)
  deadline        DateTime?
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId    String?
  department      Department?      @relation(fields: [departmentId], references: [id])
  createdBy       String
  creator         User             @relation("TaskCreator", fields: [createdBy], references: [id])
  assignees       TaskAssignee[]
  flowLogs        TaskFlowLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  @@index([organizationId])
  @@index([status])
  @@index([departmentId])
}

model TaskAssignee {
  id              String           @id @default(cuid())
  taskId          String
  task            OrganizationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          OrgTaskStatus    @default(PENDING_VIEW)
  assignedAt      DateTime         @default(now())
  completedAt     DateTime?
  @@unique([taskId, userId])
  @@index([userId])
}

model TaskFlowLog {
  id        String           @id @default(cuid())
  taskId    String
  task      OrganizationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action    String
  fromStatus String?
  toStatus   String?
  fromUser   String?
  toUser     String?
  note       String?
  createdAt  DateTime         @default(now())
  @@index([taskId])
}

model VolunteerRecord {
  id              String    @id @default(cuid())
  volunteerNumber String
  activityName    String
  activityDate    DateTime
  hours           Decimal   @default(0) @db.Decimal(4,1)
  status          VolunteerStatus @default(PENDING)
  source          String    @default("MOCK")
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([volunteerNumber])
  @@index([userId])
}

model SkillTag {
  id        String          @id @default(cuid())
  name      String
  category  SkillCategory
  createdAt DateTime        @default(now())
  users     UserSkillTag[]
  @@unique([name, category])
}

model UserSkillTag {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillTagId String
  skillTag  SkillTag  @relation(fields: [skillTagId], references: [id], onDelete: Cascade)
  level     Int       @default(1)
  createdAt DateTime  @default(now())
  @@unique([userId, skillTagId])
  @@index([userId])
}

model Award {
  id          String        @id @default(cuid())
  title       String
  level       String?
  awardDate   DateTime?
  description String?
  certificateUrl String?
  status      AwardStatus   @default(PENDING_REVIEW)
  reviewNote  String?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@index([userId])
  @@index([status])
}

model AuditLog {
  id             String       @id @default(cuid())
  action         String
  targetType     String
  targetId       String
  operatorId     String
  operator       User         @relation(fields: [operatorId], references: [id])
  detail         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  @@index([targetType, targetId])
  @@index([operatorId])
  @@index([organizationId])
}

enum Role {
  STUDENT
  ORG_LEADER
  COMMITTEE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskSource {
  MANUAL
  ORG_SYNC
  VOLUNTEER
  PRACTICE
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum OrganizationNature {
  STUDENT_ORG
  FACULTY_DEPT
  ADMIN_DEPT
  VOLUNTEER_ORG
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum TaskType {
  SINGLE_DEPT
  CROSS_DEPT
  HIERARCHICAL
}

enum OrgTaskStatus {
  PENDING_VIEW
  VIEWED
  IN_PROGRESS
  COMPLETED
}

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SkillCategory {
  TECHNICAL
  PLANNING
  MANAGEMENT
  SPORTS
}

enum AwardStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}
